# ── Nebula 生产环境变量 ──────────────────────────────────────────
# 使用方式：
#   docker compose -f docker-compose.production.yml --env-file .env up -d

# ── 镜像版本 ──────────────────────────────────────────────────────
# 指定部署版本标签，latest 或日期标签如 20260611
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# ── 服务端口 ──────────────────────────────────────────────────────
BACKEND_PORT=3030
APISIX_HTTP_PORT=80
# APISIX_HTTPS_PORT=9443          # 未来启用 HTTPS 时取消注释
# APISIX_PROMETHEUS_PORT=9180     # 未来启用 Prometheus 时取消注释
FRONTEND_PORT=80
MPMCP_SSH_PORT=2222               # pymeep 仿真环境 SSH 端口

# ── 后端配置 ──────────────────────────────────────────────────────
NEBULA_SERVER_ADDR=0.0.0.0:3030
RUST_LOG=nebula_ffi=info,tower_http=info

# ── 腾讯云 TCR 镜像仓库地址 ───────────────────────────────────────
BACKEND_IMAGE=ccr.ccs.tencentyun.com/igipme.nebula/nebula.backend
FRONTEND_IMAGE=ccr.ccs.tencentyun.com/igipme.nebula/nebula.frontend
